# ─────────────────────────────────────────────────────────────────────────
# Variables d'environnement Madger
# Copie ce fichier en .env.local (jamais commité) pour le dev, et renseigne
# les mêmes clés dans Vercel → Settings → Environment Variables pour la prod.
# ─────────────────────────────────────────────────────────────────────────

# ── Supabase (déjà utilisé par la landing) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# NOUVEAU pour l'app (auth côté navigateur) — Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Emails transactionnels (déjà utilisé par la landing) ────────────────
RESEND_API_KEY=

# ── URL publique de l'app (pour les liens, redirections OAuth, etc.) ─────
NEXT_PUBLIC_APP_URL=https://madger.app

# ── Auth Google (Phase 1) ───────────────────────────────────────────────
# Le Client ID / Secret se renseignent dans Supabase → Auth → Providers →
# Google. Ces variables servent à l'accès Calendar/Meet (Phase 4).

# ── Google Calendar + Meet (Phase 4) ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Stripe Connect (Phase 4) ────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── SMS — rappels (Phase 4) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
